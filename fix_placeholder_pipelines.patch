+    "print(f'\\nHeld-out bagimli RISKLI kural sayisi: {int(n_risk)}')\n",
+    "print('(NORMAL ve NEG_ULCER hicbir sette ateslenmiyor; kohortta normal mukoza/nege-ulser ifadesi yok.)')"
