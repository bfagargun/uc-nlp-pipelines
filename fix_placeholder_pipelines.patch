+    "# ============================================================================\n",
+    "#  PATIENT- vs PROCEDURE-LEVEL BASELINE  (reviewer fix #3: denominator clarity)\n",
+    "#  Self-contained, runnable in a fresh kernel. Reads v8.xlsx directly.\n",
+    "#  Sex is constant within patient -> patient-level is unambiguous.\n",
+    "#  Age varies within patient across procedures -> patient-level age is taken\n",
+    "#  at each patient's FIRST (earliest) endoscopy = baseline age.\n",
+    "# ============================================================================\n",
+    "import pandas as pd, numpy as np\n",
+    "\n",
+    "DATA_PATH, SHEET = \"v8.xlsx\", \"mayo-tumhastalar.rtf\"\n",
+    "PID, AGE, SEX, DATE = \"national_id\", \"age\", \"gender\", \"endoscopy_date\"\n",
+    "MALE_TOKEN = \"Erkek\"\n",
+    "\n",
+    "df = pd.read_excel(DATA_PATH, sheet_name=SHEET)\n",
+    "df_age = df[df[AGE] <= 100]                       # drop 1 data-entry outlier (>100 yrs)\n",
+    "\n",
+    "def line(lbl, v): print(f\"  {lbl:32s} {v}\")\n",
+    "\n",
+    "# ---------------- PROCEDURE-LEVEL (denominator = 830) ----------------\n",
+    "print(\"=\"*64); print(\" PROCEDURE-LEVEL  (denominator = procedures)\"); print(\"=\"*64)\n",
+    "n_proc = len(df); male_proc = int((df[SEX] == MALE_TOKEN).sum())\n",
+    "line(\"n procedures\", n_proc)\n",
+    "line(\"mean age +/- SD\", f\"{df_age[AGE].mean():.1f} +/- {df_age[AGE].std():.1f}\")\n",
+    "line(\"median age [IQR]\", f\"{df_age[AGE].median():.0f} [{df_age[AGE].quantile(.25):.0f}-{df_age[AGE].quantile(.75):.0f}]\")\n",
+    "line(\"male\", f\"{male_proc}/{n_proc} ({100*male_proc/n_proc:.1f}%)\")\n",
+    "\n",
+    "# ---------------- PATIENT-LEVEL (denominator = 499) ----------------\n",
+    "# one row per patient = earliest endoscopy (baseline)\n",
+    "first = (df.sort_values(DATE).drop_duplicates(subset=PID, keep=\"first\").copy())\n",
+    "first_age = first[first[AGE] <= 100]\n",
+    "print(\"\\n\"+\"=\"*64); print(\" PATIENT-LEVEL  (denominator = patients; age at first endoscopy)\"); print(\"=\"*64)\n",
+    "n_pat = first[PID].nunique(); male_pat = int((first[SEX] == MALE_TOKEN).sum())\n",
+    "line(\"n patients\", n_pat)\n",
+    "line(\"mean baseline age +/- SD\", f\"{first_age[AGE].mean():.1f} +/- {first_age[AGE].std():.1f}  (n={len(first_age)})\")\n",
+    "line(\"median baseline age [IQR]\", f\"{first_age[AGE].median():.0f} [{first_age[AGE].quantile(.25):.0f}-{first_age[AGE].quantile(.75):.0f}]\")\n",
+    "line(\"male\", f\"{male_pat}/{n_pat} ({100*male_pat/n_pat:.1f}%)\")\n",
+    "\n",
+    "# ---------------- data-quality flag ----------------\n",
+    "spread = df_age.groupby(PID)[AGE].agg([\"min\",\"max\"]); spread[\"range\"] = spread[\"max\"]-spread[\"min\"]\n",
+    "n_var = int((spread[\"range\"] > 5).sum())            # >5 yr swing is implausible for the span\n",
+    "print(\"\\n\"+\"=\"*64); print(\" DATA-QUALITY NOTE\"); print(\"=\"*64)\n",
+    "line(\"patients w/ within-patient\", \"\")\n",
+    "line(\"  age range > 5 yrs\", f\"{n_var}  (max {int(spread['range'].max())} yrs)\")\n",
+    "print(\"  -> within-patient age should track the 2022-2026 span (<=4 yrs).\")\n",
+    "print(\"     Larger swings indicate age data-entry inconsistency worth a spot-check;\")\n",
+    "print(\"     using age at FIRST endoscopy (above) sidesteps it for the baseline table.\")"
