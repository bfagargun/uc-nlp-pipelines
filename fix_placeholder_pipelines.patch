+    "# ============================================================================\n",
+    "#  TABLE 3 + TABLE 4 — patient-clustered bootstrap 95% CIs\n",
+    "#  Reviewer fix #2: \"no CIs reported\" in the validation tables.\n",
+    "#  Self-contained, fast (numpy-index resampling + progress), runnable in a\n",
+    "#  fresh kernel. All inputs come from v8.xlsx — no other notebook needed.\n",
+    "# ============================================================================\n",
+    "import numpy as np, pandas as pd, re, time\n",
+    "from scipy.stats import spearmanr\n",
+    "from sklearn.metrics import cohen_kappa_score, accuracy_score, f1_score, roc_auc_score\n",
+    "\n",
+    "DATA_PATH  = \"v8.xlsx\"\n",
+    "SHEET_NAME = \"mayo-tumhastalar.rtf\"\n",
+    "N_BOOT, SEED = 2000, 20240601\n",
+    "SPLIT_DATE = pd.Timestamp(\"2025-03-01\")\n",
+    "PID, MES, NHIR, NHINL = 'national_id', 'mayo_num', 'nancy_index_cagatay', 'nlp_nancy'\n",
+    "MES_TANI, MES_BULG = 'nlp_mayo_from_tanı', 'nlp_mayo_from_bulgular'\n",
+    "rng = np.random.default_rng(SEED)\n",
+    "\n",
+    "# ----------------------- load + rebuild derived cols -----------------------\n",
+    "df = pd.read_excel(DATA_PATH, sheet_name=SHEET_NAME)\n",
+    "def normalize(t):\n",
+    "    if not isinstance(t,str): return \"\"\n",
+    "    t=t.upper().replace('\\u0130','I')\n",
+    "    for s,d in [('\\u00dc','U'),('\\u00d6','O'),('\\u00c7','C'),('\\u015e','S'),('\\u011e','G')]: t=t.replace(s,d)\n",
+    "    return re.sub(r'\\s+',' ',t).strip()\n",
+    "def split_segments(t):\n",
+    "    s=re.split(r'(?:^|\\s)(?:I{1,4}V?|VI{0,3}|[0-9]+)[\\-\\)]\\s*',t); s=[x.strip() for x in s if x.strip()]\n",
+    "    return s if s else [t]\n",
+    "R_ULC=re.compile(r'\\b(ULSER|EROZYON)');R_NULC=re.compile(r'ULSER\\w*\\s+(GOZLENMEDI|YOK|SAPTANMADI|IZLENMEDI)')\n",
+    "R_ABS=re.compile(r'KRIPT\\s*ABSE');R_BAS=re.compile(r'BAZAL\\s+(LENFOPLAZMASITOZ|PLAZMOSITOZ|LENFOPLAZM)')\n",
+    "R_SEV=re.compile(r'SIDDETLI\\s+AKTIF');R_ACT=re.compile(r'\\bAKTIF\\b')\n",
+    "R_MILD=re.compile(r'(HAFIF|MINIMAL|SEYREK|FOKAL|ODAKSAL)\\s+(AKTIF|KRIPTIT)')\n",
+    "R_CHR=re.compile(r'KRONIK\\s+(ILTIHAP|INFLAMASYON|KOLIT|REKTIT)');R_NRM=re.compile(r'\\bNORMAL\\b|BELIRGIN\\s+DEGISIKLIK\\s+YOK')\n",
+    "R_POL=re.compile(r'(PSODOPOLIP|PSEUDOPOLIP|POLIPEKTOMI|\\bPOLIP\\b|ADENOMATOZ|ADENOM|INFLAMATUAR POLIP|IMMUNREAKSIYON)')\n",
+    "R_ILE=re.compile(r'TERMINAL ILEUM')\n",
+    "def grade_segment(seg):\n",
+    "    ip=bool(R_POL.search(seg)); il=bool(R_ILE.search(seg))\n",
+    "    if R_ULC.search(seg) and not R_NULC.search(seg) and not ip and not il: return 4\n",
+    "    ab=bool(R_ABS.search(seg));ba=bool(R_BAS.search(seg));se=bool(R_SEV.search(seg));ac=bool(R_ACT.search(seg));mi=bool(R_MILD.search(seg))\n",
+    "    if se: return 3\n",
+    "    if ab and ac and not mi: return 3\n",
+    "    if ba and ac and not mi: return 3\n",
+    "    if ab and not ip: return 3\n",
+    "    if ac: return 2\n",
+    "    if R_CHR.search(seg) or 'ILTIHAP' in seg: return 1\n",
+    "    if R_NRM.search(seg): return 0\n",
+    "    return 1\n",
+    "def classify_report(t):\n",
+    "    if not isinstance(t,str) or not t.strip(): return np.nan\n",
+    "    g=[grade_segment(s) for s in split_segments(normalize(t))]; return max(g) if g else np.nan\n",
+    "def mes_num(v):\n",
+    "    if pd.isna(v): return np.nan\n",
+    "    s=str(v).strip()\n",
+    "    if s in ('0-1','0.5'): return 0.0\n",
+    "    try: return float(int(round(float(s))))\n",
+    "    except Exception: return np.nan\n",
+    "\n",
+    "df[NHINL] = df['pathology_report'].apply(classify_report)\n",
+    "df[MES]   = df['mayo_score_classified'].apply(mes_num)\n",
+    "df['heldout'] = df['endoscopy_date'] >= SPLIT_DATE\n",
+    "print(f\"Loaded {len(df)} procedures, {df[PID].nunique()} patients | \"\n",
+    "      f\"held-out(>= {SPLIT_DATE.date()})={int(df['heldout'].sum())}  development={int((~df['heldout']).sum())}\")\n",
+    "\n",
+    "# ----------------------- generic clustered bootstrap -----------------------\n",
+    "def cluster_boot(pid, fn, progress=None):\n",
+    "    \"\"\"pid: patient-id array aligned to the closure arrays. fn(idx)->scalar.\"\"\"\n",
+    "    uniq, codes = np.unique(pid, return_inverse=True)\n",
+    "    rows = [np.where(codes==i)[0] for i in range(len(uniq))]\n",
+    "    point = fn(np.arange(len(pid)))\n",
+    "    vals=[]\n",
+    "    for _ in range(N_BOOT):\n",
+    "        ch = rng.integers(0, len(uniq), len(uniq))\n",
+    "        vals.append(fn(np.concatenate([rows[c] for c in ch])))\n",
+    "    a=np.array([v for v in vals if v is not None and not np.isnan(v)],float)\n",
+    "    return point, np.nanpercentile(a,2.5), np.nanpercentile(a,97.5)\n",
+    "\n",
+    "def show(label, p, lo, hi, pct=True):\n",
+    "    s,u=(100,'%') if pct else (1,'')\n",
+    "    print(f\"  {label:34s} {p*s:7.2f}{u}  95% CI [{lo*s:6.2f}, {hi*s:6.2f}]{u}\")\n",
+    "\n",
+    "def opchars(at, ap):\n",
+    "    \"\"\"sens/spec/ppv/npv from binary truth(at) & prediction(ap) arrays.\"\"\"\n",
+    "    tp=int(((ap==1)&(at==1)).sum());fp=int(((ap==1)&(at==0)).sum())\n",
+    "    fn_=int(((ap==0)&(at==1)).sum());tn=int(((ap==0)&(at==0)).sum())\n",
+    "    f=lambda n,d:n/d if d else np.nan\n",
+    "    return f(tp,tp+fn_),f(tn,tn+fp),f(tp,tp+fp),f(tn,tn+fn_)\n",
+    "\n",
+    "# =================== TABLE 3 — MES operating characteristics ===============\n",
+    "# MES as a test for hidden histologic activity (reference NHI>=2).\n",
+    "m3   = df[MES].notna() & df[NHIR].notna()\n",
+    "s3   = df[m3]\n",
+    "mes3 = s3[MES].to_numpy(); act3 = (s3[NHIR].to_numpy()>=2).astype(int); pid3 = s3[PID].to_numpy()\n",
+    "print(\"\\n\"+\"=\"*74)\n",
+    "print(f\" TABLE 3 — MES operating characteristics (n={len(s3)}; cluster bootstrap)\")\n",
+    "print(\"=\"*74)\n",
+    "for cut in (1,2,3):\n",
+    "    print(f\" MES >= {cut}  (endoscopic activity threshold):\")\n",
+    "    for j,lbl in enumerate(['Sensitivity','Specificity','PPV','NPV']):\n",
+    "        p,lo,hi = cluster_boot(pid3, lambda ix,cut=cut,j=j: opchars(act3[ix],(mes3[ix]>=cut).astype(int))[j])\n",
+    "        show(lbl,p,lo,hi)\n",
+    "p,lo,hi = cluster_boot(pid3, lambda ix: roc_auc_score(act3[ix], mes3[ix]) if len(np.unique(act3[ix]))==2 else np.nan)\n",
+    "show(\"AUC (MES -> NHI>=2)\", p,lo,hi, pct=False)\n",
+    "\n",
+    "# =================== TABLE 4 — NLP validation (all rows CI'd) ==============\n",
+    "print(\"\\n\"+\"=\"*74); print(\" TABLE 4 — NLP pipeline validation (cluster bootstrap)\"); print(\"=\"*74)\n",
+    "\n",
+    "# --- 4a. NHI main pipeline (full cohort) ---\n",
+    "mN  = df[NHIR].notna() & df[NHINL].notna(); sN=df[mN]\n",
+    "yt=sN[NHIR].to_numpy(); yp=sN[NHINL].to_numpy(); pidN=sN[PID].to_numpy()\n",
+    "print(f\"\\n NHI main pipeline — full cohort (n={len(sN)}):\")\n",
+    "show(\"Quadratic-weighted kappa\", *cluster_boot(pidN, lambda ix:cohen_kappa_score(yt[ix],yp[ix],weights='quadratic')), pct=False)\n",
+    "show(\"Overall accuracy\",         *cluster_boot(pidN, lambda ix:accuracy_score(yt[ix],yp[ix])))\n",
+    "show(\"Macro-F1\",                 *cluster_boot(pidN, lambda ix:f1_score(yt[ix],yp[ix],average='macro')), pct=False)\n",
+    "show(\"Binary (NHI>=2) accuracy\", *cluster_boot(pidN, lambda ix:((yp[ix]>=2).astype(int)==(yt[ix]>=2).astype(int)).mean()))\n",
+    "for j,lbl in enumerate(['Binary sensitivity','Binary specificity','Binary PPV','Binary NPV']):\n",
+    "    show(lbl, *cluster_boot(pidN, lambda ix,j=j: opchars((yt[ix]>=2).astype(int),(yp[ix]>=2).astype(int))[j]))\n",
+    "\n",
+    "# --- 4b. NHI temporal split: held-out vs development ---\n",
+    "for name, mask in [(\"Held-out (>= Mar 2025)\", mN & df['heldout']),\n",
+    "                   (\"Development (< Mar 2025)\", mN & ~df['heldout'])]:\n",
+    "    s=df[mask]; a=s[NHIR].to_numpy(); b=s[NHINL].to_numpy(); pid=s[PID].to_numpy()\n",
+    "    print(f\"\\n NHI temporal split — {name} (n={len(s)}):\")\n",
+    "    show(\"Quadratic-weighted kappa\", *cluster_boot(pid, lambda ix:cohen_kappa_score(a[ix],b[ix],weights='quadratic')), pct=False)\n",
+    "    show(\"Overall accuracy\",         *cluster_boot(pid, lambda ix:accuracy_score(a[ix],b[ix])))\n",
+    "    show(\"Binary (NHI>=2) accuracy\", *cluster_boot(pid, lambda ix:((b[ix]>=2).astype(int)==(a[ix]>=2).astype(int)).mean()))\n",
+    "\n",
+    "# --- 4c. MES diagnosis-field pipeline (nlp_mayo_from_tanı vs endoscopist) ---\n",
+    "ref = df[MES]\n",
+    "for col, title in [(MES_TANI,\"MES diagnosis-field pipeline\"),\n",
+    "                   (MES_BULG,\"MES blind narrative pipeline\")]:\n",
+    "    pr = df[col].apply(mes_num)\n",
+    "    m  = ref.notna() & pr.notna(); s=df[m]\n",
+    "    a=ref[m].to_numpy(); b=pr[m].to_numpy(); pid=s[PID].to_numpy()\n",
+    "    print(f\"\\n {title} (n={len(s)}):\")\n",
+    "    show(\"Quadratic-weighted kappa\", *cluster_boot(pid, lambda ix:cohen_kappa_score(a[ix],b[ix],weights='quadratic')), pct=False)\n",
+    "    show(\"Exact-agreement accuracy\", *cluster_boot(pid, lambda ix:(a[ix]==b[ix]).mean()))\n",
+    "    show(\"Within +/-1 grade\",        *cluster_boot(pid, lambda ix:(np.abs(a[ix]-b[ix])<=1).mean()))\n",
+    "    show(\"Binary (MES>=2) accuracy\", *cluster_boot(pid, lambda ix:((b[ix]>=2).astype(int)==(a[ix]>=2).astype(int)).mean()))\n",
+    "    for j,lbl in enumerate(['Binary sensitivity','Binary specificity']):\n",
+    "        show(lbl, *cluster_boot(pid, lambda ix,j=j: opchars((a[ix]>=2).astype(int),(b[ix]>=2).astype(int))[j]))\n",
+    "\n",
+    "print(\"\\nDone.\")"
+   ]
