+    "# ============================================================================\n",
+    "#  ONE-PROCEDURE-PER-PATIENT SENSITIVITY ANALYSIS\n",
+    "#  Reviewer fix: \"sensitivity analyses restricted to one randomly selected\n",
+    "#  procedure per patient yielded similar conclusions.\"\n",
+    "#  Self-contained, runnable in a fresh kernel. Uses v8.xlsx directly.\n",
+    "#  Only needs MES (mayo_num) + reference NHI; no NLP pipeline required.\n",
+    "# ============================================================================\n",
+    "import numpy as np, pandas as pd\n",
+    "from scipy.stats import chi2_contingency, fisher_exact\n",
+    "\n",
+    "DATA_PATH, SHEET = \"v8.xlsx\", \"mayo-tumhastalar.rtf\"\n",
+    "PID, NHIR = \"national_id\", \"nancy_index_cagatay\"\n",
+    "N_DRAWS = 500\n",
+    "\n",
+    "df = pd.read_excel(DATA_PATH, sheet_name=SHEET)\n",
+    "def mes_num(v):\n",
+    "    if pd.isna(v): return np.nan\n",
+    "    s=str(v).strip()\n",
+    "    if s in ('0-1','0.5'): return 0.0\n",
+    "    try: return float(int(round(float(s))))\n",
+    "    except Exception: return np.nan\n",
+    "df[\"mayo_num\"] = df[\"mayo_score_classified\"].apply(mes_num)\n",
+    "\n",
+    "# Restrict to procedures evaluable for the Mayo<->NHI contrast (both present),\n",
+    "# so each random draw is clean (no NaN leaking in as \"inactive\").\n",
+    "ev = df[df[\"mayo_num\"].notna() & df[NHIR].notna()].copy()\n",
+    "groups_idx = {p: g.index.to_numpy() for p, g in ev.groupby(PID)}\n",
+    "print(f\"Evaluable: {len(ev)} procedures, {len(groups_idx)} patients \"\n",
+    "      f\"(full cohort full-evaluable rows = {len(ev)})\")\n",
+    "\n",
+    "prev_rem, mayo0, mayo1, ors, p_chi, p_fis, ns = [], [], [], [], [], [], []\n",
+    "for s in range(N_DRAWS):\n",
+    "    r = np.random.default_rng(s)\n",
+    "    pick = [r.choice(ix) for ix in groups_idx.values()]      # 1 random procedure/patient\n",
+    "    d = ev.loc[pick]\n",
+    "    mes = d[\"mayo_num\"].to_numpy(); act = (d[NHIR].to_numpy() >= 2).astype(int)\n",
+    "    ns.append(len(d))\n",
+    "    rem = np.isin(mes, [0, 1]); prev_rem.append(act[rem].mean() if rem.any() else np.nan)\n",
+    "    m0, m1 = act[mes == 0], act[mes == 1]\n",
+    "    mayo0.append(m0.mean()); mayo1.append(m1.mean())\n",
+    "    a, b, c, e = (m1 == 1).sum(), (m1 == 0).sum(), (m0 == 1).sum(), (m0 == 0).sum()\n",
+    "    ct = np.array([[a, b], [c, e]])\n",
+    "    p_chi.append(chi2_contingency(ct)[1])\n",
+    "    p_fis.append(fisher_exact(ct)[1])\n",
+    "    ors.append((a*e)/(b*c) if b*c else np.nan)\n",
+    "\n",
+    "def summ(x, pct=True):\n",
+    "    x = np.array(x, float); x = x[~np.isnan(x)]; s = 100 if pct else 1; u = \"%\" if pct else \"\"\n",
+    "    return f\"median {np.median(x)*s:.1f}{u} [IQR {np.percentile(x,25)*s:.1f}-{np.percentile(x,75)*s:.1f}{u}]\"\n",
+    "\n",
+    "print(f\"\\nOne-procedure-per-patient sensitivity ({N_DRAWS} random draws, \"\n",
+    "      f\"~{int(np.median(ns))} procedures/draw)\")\n",
+    "print(\" Mayo 0 hidden activity      :\", summ(mayo0))\n",
+    "print(\" Mayo 1 hidden activity      :\", summ(mayo1))\n",
+    "print(\" Remission (MES 0-1) activity:\", summ(prev_rem))\n",
+    "print(\" Odds ratio Mayo1 vs Mayo0   :\", summ(ors, pct=False))\n",
+    "print(f\"\\n Mayo0 vs Mayo1 contrast across draws:\")\n",
+    "print(f\"   chi-square : worst-case p = {max(p_chi):.2e};  fraction p<0.001 = {np.mean(np.array(p_chi)<0.001):.3f}\")\n",
+    "print(f\"   Fisher exact: worst-case p = {max(p_fis):.2e};  fraction p<0.001 = {np.mean(np.array(p_fis)<0.001):.3f}\")"
+   ]
+  },
